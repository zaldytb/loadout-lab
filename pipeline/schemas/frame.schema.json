{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Frame",
  "description": "A racquet frame entry in the pipeline data layer. Engine-required fields are in 'required'. Pipeline-only fields (_meta, _provenance, brand) are stripped before export to data.js.",
  "type": "object",
  "required": [
    "id", "name", "year", "headSize", "strungWeight", "swingweight",
    "stiffness", "beamWidth", "pattern", "tensionRange", "balance"
  ],
  "properties": {
    "id":           { "type": "string", "pattern": "^[a-z0-9-]+$", "description": "Kebab-case unique identifier" },
    "name":         { "type": "string" },
    "year":         { "type": "integer" },
    "headSize":     { "type": "number", "description": "Head size in sq inches" },
    "strungWeight": { "type": "number", "description": "Strung weight in grams" },
    "swingweight":  { "type": "number", "description": "Swingweight in kg·cm²" },
    "stiffness":    { "type": "number", "description": "Frame stiffness (RA rating)" },
    "beamWidth":    { "type": "array", "items": { "type": "number" }, "minItems": 1, "description": "Beam width profile in mm (1–3 values)" },
    "pattern":      { "type": "string", "pattern": "^\\d+x\\d+$", "description": "String pattern e.g. 16x19" },
    "tensionRange": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2, "description": "[low, high] in lbs" },
    "balance":      { "type": "number", "description": "Balance point in cm from butt" },

    "balancePts":   { "type": "string", "description": "Human-readable balance e.g. '4 pts HL'" },
    "length":       { "type": "number", "description": "Frame length in inches" },
    "powerLevel":   { "type": "string" },
    "strokeStyle":  { "type": "string" },
    "swingSpeed":   { "type": "string" },
    "frameProfile": { "type": "string" },
    "identity":     { "type": "string" },
    "notes":        { "type": "string" },

    "brand": {
      "type": "string",
      "description": "Pipeline-only: extracted from name (first word). Stripped on export."
    },
    "_meta": {
      "type": "object",
      "description": "Pipeline-only: technology bonuses merged from FRAME_META. Stripped on export and reconstructed as FRAME_META in data.js.",
      "required": ["aeroBonus", "comfortTech", "spinTech", "genBonus"],
      "properties": {
        "aeroBonus":   { "type": "number", "description": "Aerodynamic frame benefit → power + spin. Scale: 0=none to 2+=exceptional" },
        "comfortTech": { "type": "number", "description": "Vibration-dampening tech → comfort + feel" },
        "spinTech":    { "type": "number", "description": "Textured/open-throat tech → spin" },
        "genBonus":    { "type": "number", "description": "Generation/revision improvement → small boost across all attrs" }
      },
      "additionalProperties": false
    },
    "_provenance": {
      "type": "object",
      "description": "Pipeline-only: data lineage metadata. Stripped on export.",
      "required": ["source", "dateAdded", "confidence"],
      "properties": {
        "source":          { "type": "string" },
        "dateAdded":       { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "confidence":      { "type": "string", "enum": ["high", "medium", "low", "estimated"] },
        "estimatedFields": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,

  "_validationRanges": {
    "_comment": "Ranges used by validate.js. warn = outside expected range (warn but don't break). engineNorm = the range the engine normalises over — outside this range the engine will clamp and lose discrimination.",
    "stiffness":         { "warn": [50, 80],  "error": [0, 120],  "engineNorm": [55, 72] },
    "swingweight":       { "warn": [260, 380], "error": [0, 500],  "engineNorm": [300, 340] },
    "strungWeight":      { "warn": [240, 380], "error": [0, 500],  "engineNorm": [290, 340] },
    "headSize":          { "warn": [85, 115],  "error": [0, 200],  "engineNorm": [95, 102] },
    "beamWidth_element": { "warn": [14, 32],   "error": [0, 50],   "engineNorm": [18, 27] }
  }
}
