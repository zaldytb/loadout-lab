{
  "name": "frame-gui",
  "version": "1.0.0",
  "description": "Desktop GUI for batch importing tennis frames into Loadout Lab",
  "main": "main.js",
  "scripts": {
    "start":       "electron .",
    "build:win":   "electron-builder --win --x64",
    "build:mac":   "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.loadoutlab.framegui",
    "productName": "Loadout Lab Frame Editor",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Loadout Lab Frame Editor",
      "artifactName": "FrameGuiSetup.exe"
    },
    "linux": {
      "target": ["AppImage"]
    },
    "mac": {
      "target": ["dmg"]
    }
  },
  "devDependencies": {
    "electron": "28.0.0",
    "electron-builder": "^24.0.0"
  }
}
